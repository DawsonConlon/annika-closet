# Copy this file to .env.local and fill in the values.
# Both settings are optional: the app works with neither.

# A free Hugging Face token raises the free GPU quota, so you hit
# "GPU is busy" less often. Get one at https://huggingface.co/settings/tokens
# ("Read" access is enough). No credit card required.
HF_TOKEN=""

# Point at a different try-on Space without changing code.
# Alternates that also work: zhengchong/CatVTON, levihsu/OOTDiffusion
# TRYON_SPACE="yisol/IDM-VTON"
